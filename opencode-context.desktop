[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=inode/directory;
Actions=aa_opencode;_SEPARATOR_;zz_configure;
X-KDE-Priority=TopLevel

[Desktop Action aa_opencode]
Name=Open AI Assistant Here
Icon=lambda-ai
Exec=%h/.local/bin/terminal-launch.sh %f

[Desktop Action zz_configure]
Name=Configure AI Assistant
Icon=lambda-cog
Exec=%h/.local/bin/ai-config.sh